APP_NAME=AI智能备考复习平台
APP_ENV=dev
DEBUG=true

DATABASE_URL=postgresql+asyncpg://ai_study:ai_study_pwd@localhost:5432/ai_study_db
REDIS_URL=redis://localhost:6379/0

JWT_SECRET_KEY=change-this-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Optional first-admin bootstrap. If username/password are blank, startup skips admin creation.
# Once any admin user exists, these values are ignored and will not overwrite credentials.
INITIAL_ADMIN_USERNAME=
INITIAL_ADMIN_PASSWORD=
INITIAL_ADMIN_DISPLAY_NAME=

UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

OCR_LANGUAGES=chi_sim+eng
OCR_TIMEOUT_SECONDS=30
OCR_IMAGE_SCALE=1.5
OCR_BINARIZE_THRESHOLD=180
OCR_MIN_TEXT_LENGTH=10
OCR_BAD_CHAR_RATIO=0.35
PDF_OCR_DPI=200
PDF_OCR_MAX_PAGES=20
PARSED_TEXT_MAX_CHARS=20000

VISION_ENABLED=false
VISION_PROVIDER=openrouter
VISION_API_KEY=
VISION_BASE_URL=https://openrouter.ai/api/v1
VISION_MODEL=google/gemini-3.1-flash-lite-preview
VISION_TIMEOUT_SECONDS=60
VISION_MAX_PAGES=5
VISION_MAX_IMAGE_BYTES=4000000
VISION_RESPONSE_FORMAT_JSON=true
VISION_FALLBACK_ON_OCR_FAILURE=true
VISION_FALLBACK_ON_LOW_QUALITY=false

AI_PROVIDER=mock
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=
AI_TIMEOUT_SECONDS=30

# 平台本地 AI token 计费配置，单位为每 1000 token 的估算价格。
# 这是 NERD 自己的展示/统计规则，不需要与 DeepSeek 或其他供应商官方账单完全一致。
AI_BILLING_CURRENCY=CNY
AI_BILLING_POLICY_VERSION=local-token-v1
AI_PRICE_PROMPT_PER_1K_TOKENS=0
AI_PRICE_COMPLETION_PER_1K_TOKENS=0
AI_PRICE_CACHE_HIT_PROMPT_PER_1K_TOKENS=
AI_PRICE_CACHE_MISS_PROMPT_PER_1K_TOKENS=
AI_PRICE_REASONING_PER_1K_TOKENS=
