APP_NAME=AI智能备考复习平台
APP_ENV=dev
DEBUG=true

DATABASE_URL=postgresql+asyncpg://ai_study:ai_study_pwd@localhost:5432/ai_study_db
REDIS_URL=redis://localhost:6379/0

JWT_SECRET_KEY=change-this-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173

# Optional Docker build mirrors. Keep the default values unless Debian package
# downloads are unstable in your network.
DEBIAN_MIRROR=http://deb.debian.org/debian
DEBIAN_SECURITY_MIRROR=http://deb.debian.org/debian-security

OCR_LANGUAGES=chi_sim+eng
OCR_TIMEOUT_SECONDS=30
OCR_IMAGE_SCALE=1.5
OCR_BINARIZE_THRESHOLD=180
OCR_MIN_TEXT_LENGTH=10
OCR_BAD_CHAR_RATIO=0.35
PDF_OCR_DPI=200
PDF_OCR_MAX_PAGES=20
PARSED_TEXT_MAX_CHARS=20000

AI_PROVIDER=mock
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=
AI_TIMEOUT_SECONDS=30

# 平台本地 AI token 计费配置，单位为每 1000 token 的估算价格。
# 这是 NERD 自己的展示/统计规则，不需要与 DeepSeek 或其他供应商官方账单完全一致。
AI_BILLING_CURRENCY=CNY
AI_BILLING_POLICY_VERSION=local-token-v1
AI_PRICE_PROMPT_PER_1K_TOKENS=0
AI_PRICE_COMPLETION_PER_1K_TOKENS=0
AI_PRICE_CACHE_HIT_PROMPT_PER_1K_TOKENS=
AI_PRICE_CACHE_MISS_PROMPT_PER_1K_TOKENS=
AI_PRICE_REASONING_PER_1K_TOKENS=
